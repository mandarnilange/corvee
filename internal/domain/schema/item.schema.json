{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/mandarnilange/corvee/internal/domain/schema/item.schema.json",
  "title": "Item",
  "description": "Per-item record persisted at .tasks/items/<id>.json. Required fields are §5 minimum; everything else is optional. Type-specific constraints (epic-only deliverable, etc.) are not enforced here — they live in usecase rules.",
  "type": "object",
  "required": [
    "schema_version",
    "id",
    "type",
    "title",
    "status",
    "created_at",
    "updated_at",
    "version"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "integer",
      "minimum": 1
    },
    "id": {
      "type": "string",
      "pattern": "^[A-Z]{3,6}(-E\\d{2}(-S\\d{2}(-T\\d{2})?)?)?$"
    },
    "type": {
      "type": "string",
      "enum": ["project", "epic", "story", "subtask"]
    },
    "kind": {
      "type": "string",
      "enum": ["feature", "bug", "chore", "spike", "docs", "refactor"]
    },
    "project_id": {
      "type": "string"
    },
    "parent_id": {
      "type": "string"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "backlog",
        "ready",
        "claimed",
        "in_progress",
        "review",
        "blocked",
        "done",
        "abandoned"
      ]
    },
    "priority": {
      "type": "string",
      "enum": ["critical", "high", "medium", "low"]
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "deliverable": {
      "type": "string"
    },
    "claim": {
      "type": "object",
      "required": ["agent", "lease_id", "claimed_at", "expires_at"],
      "additionalProperties": false,
      "properties": {
        "agent": { "type": "string" },
        "lease_id": { "type": "string" },
        "claimed_at": { "type": "string", "format": "date-time" },
        "expires_at": { "type": "string", "format": "date-time" }
      }
    },
    "required_capabilities": {
      "type": "array",
      "items": { "type": "string" }
    },
    "created_at": { "type": "string", "format": "date-time" },
    "created_by": { "type": "string" },
    "created_by_role": {
      "type": "string",
      "enum": ["planner", "executor", "reviewer", "human"]
    },
    "updated_at": { "type": "string", "format": "date-time" },
    "completed_at": { "type": ["string", "null"], "format": "date-time" },
    "due_date": { "type": ["string", "null"], "format": "date-time" },
    "version": { "type": "integer", "minimum": 1 },
    "impact": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "files": { "type": "array", "items": { "type": "string" } },
        "modules": { "type": "array", "items": { "type": "string" } },
        "estimated_hours": { "type": "number", "minimum": 0 },
        "estimated_loc": { "type": "integer", "minimum": 0 },
        "risk": { "type": "string", "enum": ["low", "medium", "high"] }
      }
    },
    "dependencies": {
      "type": "array",
      "items": { "type": "string" }
    },
    "blocks": {
      "type": "array",
      "items": { "type": "string" }
    },
    "aliases": {
      "type": "array",
      "items": { "type": "string" }
    },
    "acceptance_criteria": {
      "type": "array",
      "items": { "type": "string" }
    },
    "journal": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["ts", "actor", "event"],
        "additionalProperties": false,
        "properties": {
          "ts": { "type": "string", "format": "date-time" },
          "actor": { "type": "string" },
          "event": { "type": "string" },
          "note": { "type": "string" },
          "metadata": { "type": "object" }
        }
      }
    }
  }
}
